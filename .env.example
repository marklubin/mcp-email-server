# MCP Router Configuration
# Copy this file to .env and fill in your values

# API key for authenticating requests from Cloudflare Worker
MCP_SECRET=your-secret-key-here

# Router settings
ROUTER_HOST=127.0.0.1
ROUTER_PORT=8080

# --- Email backend (ProtonMail Bridge) ---
# Run `protonmail-bridge --cli` > info to get these
PROTON_BRIDGE_HOST=127.0.0.1
PROTON_BRIDGE_IMAP_PORT=1143
PROTON_BRIDGE_SMTP_PORT=1025
PROTON_BRIDGE_USER=your-email@proton.me
PROTON_BRIDGE_PASSWORD=bridge-generated-password

# --- Browser backend ---
# CDP-exposed Chromium/Firefox; see scripts/run-headless-*.sh
BROWSER_CDP_HOST=127.0.0.1
BROWSER_CDP_PORT=9222

# --- Todoist backend ---
TODOIST_API_TOKEN=

# --- Discord backend ---
# User token — extract via browser.discord_extract_token() or paste manually
DISCORD_TOKEN=

# --- Twitter backend ---
# Key from https://twitterapi.io
TWITTERAPI_IO_KEY=

# --- Memory backend ---
# Agent-mesh / synix knowledge server
MESH_SERVER_URL=
MESH_TOKEN=

# --- Unified memory backend (optional, not mounted by default) ---
# Synix MCP server to proxy; overrides MESH_* if unified_memory is mounted instead of memory
AGENT_MESH_MCP_URL=http://salinas:8200/mcp

# --- Web search backend (Exa) ---
# Free tier: 1,000 searches/month. Sign up at https://dashboard.exa.ai
EXA_API_KEY=
